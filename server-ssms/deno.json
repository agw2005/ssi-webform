{
  "name": "@scope/server-ssms",
  "version": "0.0.0",
  "exports": "./mod.ts",
  "tasks": {
    "dev": "deno run --watch --allow-env --env-file=.env --allow-net --allow-read main.ts",
    "serve": "deno run --allow-env --env-file=.env --allow-net --allow-read main.ts",
    "build": "deno compile --allow-env --env-file=.env --allow-net --allow-read --target x86_64-unknown-linux-gnu --output webform-oak-server main.ts",
    "keygen": "deno run --allow-read --allow-write ./auth/generateKey.ts"
  },
  "imports": {
    "@oak/oak": "jsr:@oak/oak@^17.2.0",
    "@std/encoding": "jsr:@std/encoding@^1.0.10",
    "@types/mssql": "npm:@types/mssql@^9.1.11",
    "@zaubrik/djwt": "jsr:@zaubrik/djwt@^3.0.2",
    "mssql": "npm:mssql@^12.2.1"
  }
}
